{
  "Django ORM Get Object": {
    "prefix": "djget",
    "body": [
      "from django.shortcuts import get_object_or_404",
      "",
      "${1:object_var} = get_object_or_404(${2:ModelName}, ${3:field}=${4:value})"
    ]
  },
  "Django ORM Filter Query": {
    "prefix": "djfilter",
    "body": [
      "${1:queryset} = ${2:ModelName}.objects.filter(${3:field}=${4:value})"
    ]
  },
  "Django ORM Exclude Query": {
    "prefix": "djexclude",
    "body": [
      "${1:queryset} = ${2:ModelName}.objects.exclude(${3:field}=${4:value})"
    ]
  },
  "Django ORM Order By": {
    "prefix": "djorder",
    "body": [
      "${1:queryset} = ${2:ModelName}.objects.order_by('${3:field}')"
    ]
  },
  "Django ORM Create Object": {
    "prefix": "djcreate",
    "body": [
      "${1:object_var} = ${2:ModelName}.objects.create(",
      "    ${3:field1}=${4:value1},",
      "    ${5:field2}=${6:value2}",
      ")"
    ]
  },
  "Django ORM Update Object": {
    "prefix": "djupdate",
    "body": [
      "${1:ModelName}.objects.filter(${2:field}=${3:value}).update(${4:field_to_update}=${5:new_value})"
    ]
  },
  "Django ORM Delete Object": {
    "prefix": "djdelete",
    "body": [
      "${1:ModelName}.objects.filter(${2:field}=${3:value}).delete()"
    ]
  },
  "Django ORM Get All": {
    "prefix": "djall",
    "body": [
      "${1:queryset} = ${2:ModelName}.objects.all()"
    ]
  }
}

